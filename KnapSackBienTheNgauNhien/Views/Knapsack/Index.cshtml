@{
    ViewData["Title"] = "Bước 1: Khởi tạo vật phẩm";
}
<link rel="stylesheet" href="~/css/knapsack.css" />

<style>
    /* Định dạng khung chứa có thể cuộn */
    .scrollable-zone {
        max-height: 550px; /* Chiều cao tối đa. Vượt quá sẽ hiện thanh cuộn */
        min-height:550px;
        overflow-y: auto; /* Chỉ cuộn dọc */
        overflow-x: hidden;
        padding: 15px;
        border-radius: 8px;
        align-content: flex-start; /* Các vật phẩm tự động dồn lên trên */
        background: rgba(0, 0, 0, 0.2);
        border: 2px dashed #5a6268;
        margin-top: 20px;
    }

        /* LÀM ĐẸP THANH CUỘN (SCROLLBAR) THEO PHONG CÁCH GAME */
        .scrollable-zone::-webkit-scrollbar {
            width: 10px;
        }

        .scrollable-zone::-webkit-scrollbar-track {
            background: #1a252f;
            border-radius: 8px;
        }

        .scrollable-zone::-webkit-scrollbar-thumb {
            background: #FFD700; /* Màu Vàng Gold đồng bộ với tiêu đề */
            border-radius: 8px;
            border: 2px solid #1a252f;
        }

            .scrollable-zone::-webkit-scrollbar-thumb:hover {
                background: #e6c200;
            }
</style>

<div class="knapsack-container">
    <h2 style="text-align:center; color: #FFD700; text-transform: uppercase; letter-spacing: 2px;">QUAY SỐ VẬT PHẨM</h2>
    <p style="text-align:center; color: #b0c4de; margin-bottom: 30px;">Nhấn nút xoay để làm mới thuộc tính ngẫu nhiên của các vật phẩm</p>

    <!-- HÀNG 1: SEED + QUY MÔ -->
    <div class="controls row-inline">
        <div class="control-item">
            <div class="label-group">
                <label>Nhập Mã Seed</label>
                <span>Giữ cố định dữ liệu</span>

            </div>
            <input type="number" id="seed-input" class="form-control" value="12345">
        </div>

        <div class="control-item">
            <label>Quy mô bài toán (N)</label>
            <select id="item-count">
                <option value="10">Cơ bản: 10 vật phẩm</option>
                <option value="50">Trung bình: 50 vật phẩm</option>
                <option value="100">Lớn: 100 vật phẩm</option>
                <option value="500">Rất lớn: 500 vật phẩm</option>
                <option value="1000">Cực đại: 1000 vật phẩm (Lưu ý)</option>
                <option value="5000">Thử thách: 5000 vật phẩm (Đặc biệt lưu ý!)</option>
                <option value="10000">Hủy diệt: 10000 vật phẩm (CÂN NHẮC KỸ)</option>
            </select>
        </div>
    </div>

    <div class="controls row-inline center">
        <span class="seed-note">
            Seed là giá trị dùng để khởi tạo bộ sinh số ngẫu nhiên.
            Khi sử dụng cùng một Seed, hệ thống sẽ luôn tạo ra cùng một tập dữ liệu vật phẩm theo đúng thứ tự từ 1 → N.
            Điều này có nghĩa là dù thay đổi quy mô bài toán (N = 10, 100, 1000...), các vật phẩm từ 1 → n sẽ luôn giữ nguyên thuộc tính (trọng lượng, giá trị) như ban đầu.
            Nhờ đó có thể đảm bảo tính nhất quán khi so sánh thuật toán.
        </span>
    </div>
    <!-- HÀNG 2: BUTTON -->
    <div class="controls row-inline center">
        <button class="btn" id="btn-generate" onclick="generateRandomItems()">
            Xoay ngẫu nhiên lại
        </button>

        <button class="btn btn-success" id="btn-submit" onclick="submitItems()">
            Chốt danh sách & Chơi
        </button>
    </div>

    <div class="item-grid scrollable-zone" id="item-container" style="min-height: 400px;">
    </div>
</div>

<script src="~/js/knapsack-setup.js" asp-append-version="true"></script>